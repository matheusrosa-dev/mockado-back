API_PORT=3333

# --- POSTGRESQL ---
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_DATABASE=mockado
DB_MIGRATIONS_AUTO_RUN=true

