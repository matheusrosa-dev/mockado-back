GOOGLE_CLIENT_ID=
JWT_SECRET=secret-key-for-jwt-signing
JWT_REFRESH_SECRET=secret-key-for-refresh-token-signing
JWT_EXPIRATION_TIME=900 # 15 minutes in seconds
JWT_REFRESH_EXPIRATION_TIME=604800 # 1 week in seconds