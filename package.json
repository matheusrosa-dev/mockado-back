  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "typeorm": "DOTENV_CONFIG_PATH=./envs/.env node --require dotenv/config --require ts-node/register --require tsconfig-paths/register ./node_modules/typeorm/cli.js -d ./src/nest-modules/databases/typeorm.datasource.ts",
    "migration:create": "npm run typeorm -- migration:create ./src/core/infra/shared/db/typeorm/migrations/$npm_config_name",
    "migration:generate": "npm run typeorm -- migration:generate ./src/core/infra/shared/db/typeorm/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "test": "jest",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "chance": "^1.1.13",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "eventemitter2": "^6.4.9",
    "fast-deep-equal": "^3.1.3",
    "google-auth-library": "^10.6.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.10",
